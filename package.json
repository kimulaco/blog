{
  "name": "kimulaco-blog",
  "version": "2.7.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "start": "astro dev",
    "setup:build-cache": "tsx scripts/generateBuildCache.ts",
    "dev": "BUILD_ENV=development astro dev",
    "dev:draft": "BUILD_ENV=development DRAFT=true astro dev",
    "predev": "pnpm setup:build-cache",
    "build": "astro check --minimumSeverity error && astro build",
    "build:dev": "BUILD_ENV=development pnpm run build",
    "build:prod": "BUILD_ENV=production pnpm run build",
    "prebuild": "pnpm setup:build-cache",
    "preview": "astro preview",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "playwright install --with-deps && playwright test",
    "lint": "pnpm lint:ls && pnpm lint:format && pnpm lint:script && pnpm lint:style && pnpm lint:astro",
    "lint:astro": "astro check",
    "lint:ls": "ls-lint",
    "lint:script": "oxlint .",
    "lint:style": "stylelint './src/**/*.{css,scss,astro}' --ignore-path .gitignore",
    "lint:format": "oxfmt --check . && prettier --check '**/*.astro'",
    "format": "oxfmt --write . && prettier --write '**/*.astro'",
    "format:oxfmt": "oxfmt --write .",
    "format:prettier": "prettier --write '**/*.astro'"
  },
  "dependencies": {
    "@astrojs/check": "0.9.8",
    "@astrojs/partytown": "2.1.7",
    "@astrojs/react": "5.0.4",
    "@astrojs/rss": "4.0.18",
    "@astrojs/sitemap": "3.7.2",
    "@sentry/astro": "10.50.0",
    "astro": "6.1.9",
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "normalize.css": "8.0.1",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@ls-lint/ls-lint": "2.3.1",
    "@playwright/test": "1.59.1",
    "@resvg/resvg-js": "2.6.2",
    "@types/prismjs": "1.26.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.5",
    "dotenv": "17.4.2",
    "happy-dom": "20.9.0",
    "husky": "9.1.7",
    "marked": "18.0.2",
    "microcms-js-sdk": "3.4.0",
    "oxfmt": "0.46.0",
    "oxlint": "1.61.0",
    "postcss-html": "1.8.1",
    "prettier": "3.8.3",
    "prettier-plugin-astro": "0.14.1",
    "prismjs": "1.30.0",
    "sass": "1.99.0",
    "satori": "0.26.0",
    "stylelint": "17.9.1",
    "stylelint-config-html": "1.1.0",
    "stylelint-config-standard-scss": "17.0.0",
    "stylelint-prettier": "5.0.3",
    "stylelint-scss": "7.0.0",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "vite-svg-loader": "5.1.1",
    "vitest": "4.1.5",
    "zx": "8.8.5"
  },
  "engines": {
    "node": "24.15.0"
  },
  "packageManager": "pnpm@10.33.2"
}
